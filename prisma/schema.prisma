datasource db {
  provider = "mysql"
   url      = "mysql://root:2004@localhost:3306/todo_app"
}

generator client {
  provider = "prisma-client-js"
}

model todo {
  id           String   @id @default(cuid())
  title        String
  is_completed Boolean  @default(false)
  createdAt    DateTime @default(now())
}
